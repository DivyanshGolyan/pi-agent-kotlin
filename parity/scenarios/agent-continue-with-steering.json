{
  "id": "agent-continue-with-steering",
  "suite": "pi-agent-core",
  "kind": "agent_continue_scripted",
  "model": {
    "id": "mock",
    "name": "Mock Model",
    "api": "anthropic-messages",
    "provider": "anthropic",
    "reasoning": true,
    "input": [
      "text"
    ],
    "contextWindow": 8192,
    "maxTokens": 2048
  },
  "initialState": {
    "systemPrompt": "You are helpful.",
    "thinkingLevel": "off",
    "messages": [
      {
        "role": "assistant",
        "content": [
          {
            "type": "text",
            "text": "ready"
          }
        ],
        "stopReason": "stop"
      }
    ]
  },
  "steeringMessages": [
    {
      "role": "user",
      "content": "steer-now"
    }
  ],
  "stream": {
    "tokenSize": {
      "min": 1,
      "max": 1
    }
  },
  "responses": [
    {
      "content": [
        {
          "type": "text",
          "text": "ok"
        }
      ],
      "stopReason": "stop"
    }
  ]
}
