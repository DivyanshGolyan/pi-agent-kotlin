{
  "id": "ai-stream-thinking-toolcall",
  "suite": "pi-ai-core",
  "kind": "ai_stream_faux",
  "model": {
    "id": "faux-thinker",
    "name": "Faux Thinker",
    "api": "faux:parity",
    "provider": "faux",
    "reasoning": true,
    "input": [
      "text",
      "image"
    ],
    "contextWindow": 128000,
    "maxTokens": 16384
  },
  "provider": {
    "tokenSize": {
      "min": 1,
      "max": 1
    }
  },
  "context": {
    "systemPrompt": "Think first.",
    "messages": [
      {
        "role": "user",
        "content": "Solve this with a tool."
      }
    ]
  },
  "responses": [
    {
      "content": [
        {
          "type": "thinking",
          "thinking": "step by step"
        },
        {
          "type": "toolCall",
          "id": "tool-1",
          "name": "echo",
          "arguments": {
            "value": "hello"
          }
        },
        {
          "type": "text",
          "text": "done"
        }
      ],
      "stopReason": "toolUse"
    }
  ]
}
